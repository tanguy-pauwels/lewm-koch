# Hugging Face dataset/model access
HF_TOKEN=
HF_DATASET_REPO_ID=Tpauwels/lerobot-hdf5-koch_pick_place_1_lego
HF_DATASET_PATTERNS=*.h5
HF_DATASET_FILES=
HF_FORCE_DOWNLOAD=false
HF_OUTPUT_REPO_ID=
HF_OUTPUT_PRIVATE=true
HF_UPLOAD_ALL_CHECKPOINTS=false
HF_HUB_ENABLE_HF_TRANSFER=1

# WandB tracking
WANDB_ENABLED=true
WANDB_TOKEN=
WANDB_ENTITY=
WANDB_PROJECT=le-wm-koch
WANDB_NAME=

# Training/cache layout
STABLEWM_HOME=/workspace/data
RUN_SUBDIR=
LEWM_OUTPUT_MODEL_NAME=lewm
LEWM_BATCH_SIZE=64
LEWM_PRECISION=bf16
LEWM_NUM_WORKERS=16
LEWM_EXTRA_OVERRIDES=

# Runtime dataset config rendered into src/config/train/data/
LEWM_DATASET_NAME=train__observation_images_laptop
LEWM_DATA_CONFIG_NAME=train__observation_images_laptop
LEWM_FRAME_SKIP=5
LEWM_KEYS_TO_LOAD=pixels,action,proprio,state
LEWM_KEYS_TO_CACHE=action,proprio,state

# Optional source bootstrap fallback when src/ is absent
LEWM_SOURCE_REPO=https://github.com/lucas-maes/le-wm.git
LEWM_SOURCE_REF=ca231f9f9d9ab041034b6d05e90b6e04bd6cff82
